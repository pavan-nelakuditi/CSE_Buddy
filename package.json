{
  "name": "cse-buddy",
  "version": "0.1.0",
  "description": "Workspace-first desktop app for turning one API service into a Postman onboarding bundle.",
  "author": "Postman",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "build": "npm run typecheck && npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "dev:electron": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "dist:dir": "npm run build && electron-builder --dir --mac",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "build": {
    "appId": "com.postman.cse-buddy",
    "productName": "CSE Buddy",
    "asar": true,
    "directories": {
      "output": "dist-packages",
      "buildResources": "build"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "electron/preload.cjs",
      "build/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.821.0",
    "@aws-sdk/client-apigatewayv2": "^3.821.0",
    "@aws-sdk/client-sts": "^3.821.0",
    "@aws-sdk/credential-providers": "^3.821.0",
    "@smithy/node-http-handler": "^4.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.5.1",
    "electron-builder": "^24.13.3",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
